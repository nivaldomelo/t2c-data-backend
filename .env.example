# Compatibility example for isolated backend runs.
# Canonical operational configuration lives in the repo-root .env.example.

APP_NAME=Andromeda Catalog
ENV=dev
DATABASE_URL=postgresql+psycopg://<user>:<password>@localhost:5433/andromeda
OPERATIONAL_DATABASE_URL=
INGESTION_OPERATIONAL_DATABASE_URL=
OPERATIONAL_DB_HOST=
OPERATIONAL_DB_PORT=5432
OPERATIONAL_DB_NAME=
OPERATIONAL_DB_USER=
OPERATIONAL_DB_PASSWORD=
OPERATIONAL_DB_SCHEMA=controle
DB_SCHEMA=t2c_data
JWT_SECRET_KEY=dev-only-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
DQ_EXECUTION_ENGINE=spark
USER_SESSION_RETENTION_DAYS=365
USER_ACCESS_EVENT_RETENTION_DAYS=365
AUDIT_EVENT_RETENTION_DAYS=730
EXPORT_FILE_TTL_HOURS=1
DQ_SAMPLE_RETENTION_DAYS=90
PROFILING_SAMPLE_RETENTION_DAYS=90
INCIDENT_EVIDENCE_RETENTION_DAYS=365
TEMP_FILE_TTL_HOURS=24
ROW_COUNT_SNAPSHOT_RETENTION_DAYS=180
CERTIFICATION_HISTORY_RETENTION_DAYS=365
PRIVACY_REVIEW_EVENT_RETENTION_DAYS=365
SYSTEM_LOG_RETENTION_DAYS=365
CORS_ALLOW_ORIGINS=
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
ENABLE_DB_SEED=true
INITIAL_ADMIN_NAME=Andromeda Admin
INITIAL_ADMIN_EMAIL=admin@andromeda.com
INITIAL_ADMIN_PASSWORD=
ADMIN_EMAIL=admin@andromeda.com
ADMIN_PASSWORD=change-me
VIEWER_EMAIL=viewer@t2c.local
VIEWER_PASSWORD=change-me

AIRFLOW_SOURCE_SCHEMA=airflow_meta
AIRFLOW_METADATA_CONTRACT_VERSION=v1

# --- Produção / Kubernetes (Turn2C) ---
# ENV: use dev | prd | apc (qualquer valor != dev/development/local/test = produção).
# RDS gerenciado SEMPRE com SSL na string de conexão:
#   DATABASE_URL=postgresql+psycopg://USER:***@HOST:5432/DB?sslmode=require
# Logs estruturados JSON em stdout (recomendado no cluster):
LOG_JSON=false
# AWS (IRSA ainda não é padrão -> chaves via Secret do cluster; boto3 lê do ambiente):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# CORS_ALLOW_ORIGINS: domínio do frontend (CloudFront), separado por vírgula. Nunca "*" em prod.
